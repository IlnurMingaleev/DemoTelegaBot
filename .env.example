# Telegram Bot Token from @BotFather
BOT_TOKEN=8212663017:AAG3W32VV0KCzoOd3u5h3Cqq4BQ7hTKCBEE

# ─── Railway deployment ────────────────────────────────────────────────────────
# On Railway these two variables are injected automatically — do NOT set them
# manually there. Just add BOT_TOKEN and everything else is auto-configured.
#
#   RAILWAY_PUBLIC_DOMAIN  → set by Railway; triggers webhook mode automatically
#   PORT                   → set by Railway; used as the webhook server port
#
# ─── Local / manual server ────────────────────────────────────────────────────
# Run mode: "polling" (local dev) or "webhook" (VPS / manual server)
MODE=polling

# Webhook settings (only needed for MODE=webhook on a manual server)
WEBHOOK_URL=https://yourdomain.com
WEBHOOK_PORT=8443
WEBHOOK_SECRET=your_random_secret_here

# ─── Bot settings ─────────────────────────────────────────────────────────────
# Whisper model size: tiny | small | medium
# tiny=fastest (low RAM), small=balanced (recommended), medium=most accurate
# Railway free tier: use "tiny" to stay within memory limits
WHISPER_MODEL_SIZE=small

# Path to SQLite database file
# On Railway: mount a Volume to /data and leave this as-is to persist reminders
DB_PATH=reminders.db
